# Copy this to .env and fill in your values
# cp .env.example .env

# Required: path to your Obsidian vault folder where notes will be saved
OBSIDIAN_VAULT=/Users/yourname/path/to/your/obsidian/vault

# Optional: Claude API key for AI-powered description analysis (uses Haiku, ~$0.35/week)
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
